# Database
MONGODB_URI=mongodb://localhost:27017/revision-master

# Auth
BETTER_AUTH_SECRET=super-secret-local-dev-key-change-in-production-32chars
BETTER_AUTH_URL=http://localhost:3000

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Gemini API (per-user key stored encrypted in DB; this is the fallback server key)
GEMINI_API_KEY=your-gemini-api-key-here
AUDIO_STORAGE_BACKEND=mongodb
NEXT_PUBLIC_AUDIO_STORAGE_BACKEND=mongodb
