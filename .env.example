# ─── Database ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ─── App ──────────────────────────────────────────────────────────────────────
# Base URL used for OAuth redirects and password-reset links (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Encryption ───────────────────────────────────────────────────────────────
# 32-character random hex string — used to encrypt user Gemini API keys at rest
ENCRYPTION_KEY=<32-char-hex-secret>

# ─── Email (Nodemailer / Gmail SMTP) ──────────────────────────────────────────
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=<16-char-google-app-password>

# ─── OAuth — Google ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=<google-oauth-client-id>
GOOGLE_CLIENT_SECRET=<google-oauth-client-secret>

# ─── OAuth — GitHub ───────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=<github-oauth-client-id>
GITHUB_CLIENT_SECRET=<github-oauth-client-secret>

# ─── OAuth — Discord ──────────────────────────────────────────────────────────
DISCORD_CLIENT_ID=<discord-oauth-client-id>
DISCORD_CLIENT_SECRET=<discord-oauth-client-secret>

# ─── Audio Storage ────────────────────────────────────────────────────────────
# Where to store uploaded audio files: "cloudinary" | "mongodb"
# Use "mongodb" temporarily to skip Cloudinary setup (stores file as Base64 in DB, not for production)
AUDIO_STORAGE_BACKEND=mongodb
# Client-side mirror of the above — required for the upload form to branch correctly
NEXT_PUBLIC_AUDIO_STORAGE_BACKEND=mongodb

# ─── Cloudinary (server-side — signed asset deletion) ─────────────────────────
CLOUDINARY_CLOUD_NAME=<your-cloud-name>
CLOUDINARY_API_KEY=<your-api-key>
CLOUDINARY_API_SECRET=<your-api-secret>

# ─── Cloudinary (client-side — unsigned uploads) ──────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=<your-cloud-name>
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=<your-unsigned-upload-preset>
